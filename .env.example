# ─── Application ──────────────────────────────────────────────
APP_NAME=RCA-Agent
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false

# ─── Ollama ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120
OLLAMA_TEMPERATURE=0.1

# ─── Kubernetes ───────────────────────────────────────────────
K8S_CONFIG_TYPE=in_cluster     # in_cluster | kubeconfig | auto
K8S_KUBECONFIG_PATH=~/.kube/config
K8S_CONTEXT=k3d-rca-cluster
K8S_DEFAULT_NAMESPACE=default
K8S_LOG_TAIL_LINES=200

# ─── ChromaDB ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_INCIDENTS=rca_incidents
CHROMA_COLLECTION_KNOWLEDGE=rca_knowledge
CHROMA_EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_TOP_K=5

# ─── SQLite ───────────────────────────────────────────────────
SQLITE_DB_PATH=./data/sqlite/rca_incidents.db

# ─── Prometheus ───────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_TIMEOUT=30

# ─── FastAPI ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]

# ─── Streamlit ────────────────────────────────────────────────
STREAMLIT_PORT=8501

# ─── Reports ──────────────────────────────────────────────────
REPORTS_OUTPUT_DIR=./data/reports
REPORTS_COMPANY_NAME=Platform Engineering
